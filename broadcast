#!/bin/bash
# broadcast — Run a command or copy a file across all VMSS nodes via SSH.
#
# Usage:
#   broadcast <command>                           Run command on all nodes
#   broadcast --copy <local-path> <remote-path>  Copy file to all nodes
#
# Requires ~/node-conf/cluster-hosts.txt (one IP per line)

set -e

HOSTS_FILE="$HOME/node-conf/cluster-hosts.txt"
SELF_IP=$(ip -4 addr show eth1 | grep -oP 'inet \K[\d.]+')

if [ ! -f "$HOSTS_FILE" ]; then
    echo "ERROR: $HOSTS_FILE not found. Run post-deploy.ps1 first."
    exit 1
fi

if [ "$1" = "--copy" ]; then
    LOCAL_PATH="${2:?Usage: broadcast --copy <local> <remote>}"
    REMOTE_PATH="${3:?Usage: broadcast --copy <local> <remote>}"
    echo "=== Broadcasting file: $LOCAL_PATH → $REMOTE_PATH ==="

    while IFS= read -r IP; do
        [ -z "$IP" ] && continue
        [ "$IP" = "$SELF_IP" ] && continue
        scp -q "$LOCAL_PATH" "guser@$IP:$REMOTE_PATH" &
    done < "$HOSTS_FILE"
    wait
    # Also copy locally
    [ "$LOCAL_PATH" != "$REMOTE_PATH" ] && cp "$LOCAL_PATH" "$REMOTE_PATH"
    echo "Done."

else
    CMD="${1:?Usage: broadcast <command> | broadcast --copy <local> <remote>}"
    echo "=== Broadcasting command: $CMD ==="

    while IFS= read -r IP; do
        [ -z "$IP" ] && continue
        [ "$IP" = "$SELF_IP" ] && continue
        ssh -o ConnectTimeout=5 "guser@$IP" "$CMD" &
    done < "$HOSTS_FILE"
    wait
    # Also run locally
    eval "$CMD"
    echo "Done."
fi
